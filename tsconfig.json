{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "noEmit": true,
    "rootDir": "./extensions",
    "baseUrl": ".",
    "paths": {
      "@/*": ["extensions/*"]
    }
  },
  "include": ["extensions/**/*"],
  "exclude": ["node_modules"]
}
